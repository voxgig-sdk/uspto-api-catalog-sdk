          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/patent-assignment/v1.4": {
      "get": {
        "tags": [
          "Patents"
        ],
        "summary": "Patent Assignment Search API",
        "description": "Use this API to retrieve patent assignment information from the USPTO assignment search database and generate XML files.",
        "operationId": "getPatentAssignments",
        "parameters": [
          {
            "name": "searchQuery",
            "in": "query",
            "description": "Search query for patent assignments",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format (xml or json)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "xml",
                "json"
              ],
              "default": "xml"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with patent assignment data",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "object"
                }
              },
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "assignments": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "assignmentId": {
                            "type": "string"
                          },
                          "patentNumber": {
                            "type": "string"
                          },
                          "assignor": {
                            "type": "string"
                          },
                          "assignee": {
                            "type": "string"
                          },
                          "assignmentDate": {
                            "type": "string",
                            "format": "date"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - API key required"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "name": "X-API-KEY",
        "in": "header",
        "description": "API key required for accessing USPTO APIs. Request an API key from the USPTO Open Data Portal."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "statusCode": {
            "type": "integer"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Patents",
      "description": "APIs related to patent data and operations"
    },
    {
      "name": "Trademarks",
      "description": "APIs related to trademark data and operations"
    },
    {
      "name": "PTAB",
      "description": "Patent Trial and Appeal Board related APIs"
    }
  ],
  "externalDocs": {
    "description": "USPTO API Catalog Documentation",
    "url": "https://developer.uspto.gov/api-catalog"
  }
}
