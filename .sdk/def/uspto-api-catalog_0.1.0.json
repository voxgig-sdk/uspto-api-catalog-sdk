            "description": "Citations not found"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/office-action-rejections/v2": {
      "get": {
        "tags": [
          "Patents"
        ],
        "summary": "USPTO Office Action Rejection API",
        "description": "Retrieve office action rejection data. Notice: In early 2026, this product will be decommissioned and migrated to the new Open Data Portal.",
        "operationId": "getOfficeActionRejections",
        "parameters": [
          {
            "name": "applicationNumber",
            "in": "query",
            "description": "Patent application number",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with office action rejections",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
